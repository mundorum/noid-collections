{
  "title": "Text source → console display",
  "imports": [
    "../noid_collections/slm_agents/text_source/text_source.py",
    "../noid_collections/slm_agents/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "slm:text-source",
      "id":   "src",
      "properties": {
        "label":        "greeting",
        "text":         "Hello from the text source!",
        "auto_publish": true
      },
      "publish": "text~pipeline/text;done~player/done"
    },
    {
      "type": "slm:console-display",
      "id":   "display",
      "properties": {"label": "Text"},
      "subscribe": "pipeline/text~show"
    }
  ]
}
