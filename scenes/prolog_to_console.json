{
  "title": "Prolog reasoning → console display",
  "imports": [
    "../noid_collections/slm_agents/text_source/text_source.py",
    "../noid_collections/slm_agents/prolog/prolog.py",
    "../noid_collections/slm_agents/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "slm:text-source",
      "id":   "trigger",
      "properties": {
        "label":        "query",
        "text":         "mortal(X)",
        "auto_publish": true
      },
      "publish": "text~pipeline/query-in"
    },
    {
      "type": "slm:prolog",
      "id":   "reasoner",
      "properties": {
        "facts_rules": "human(socrates).\nhuman(plato).\nmortal(X) :- human(X)."
      },
      "subscribe": "pipeline/query-in~query",
      "publish":   "result~pipeline/result;error~pipeline/result;result~player/done"
    },
    {
      "type": "slm:console-display",
      "id":   "display",
      "properties": {"label": "Prolog"},
      "subscribe": "pipeline/result~show"
    }
  ]
}
