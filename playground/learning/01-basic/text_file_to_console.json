{
  "title": "Text source → console display",
  "namespaces": {
    "scene": {
      "kind": "resource",
      "root": "."
    }
  },
  "imports": [
    "../../../noid_collections/data/text_source/text_source.py",
    "../../../noid_collections/basic/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "data:text-source",
      "id":   "src",
      "properties": {
        "label": "dinosaur",
        "file":  "scene:dinosaur.txt"
      },
      "subscribe": "player/start~load",
      "publish": "text~pipeline/text;done~player/done"
    },
    {
      "type": "basic:console-display",
      "id":   "display",
      "properties": {"label": "Text"},
      "subscribe": "pipeline/text~show",
      "publish": "output~player/done"
    }
  ]
}
