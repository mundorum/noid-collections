{
  "title": "SLM Agents demo — CSV row-by-row through LLM",
  "imports": [
    "../noid_collections/slm_agents/csv_source/csv_source.py",
    "../noid_collections/slm_agents/llm/llm.py",
    "../noid_collections/slm_agents/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "slm:csv-source",
      "id":   "csv",
      "properties": {
        "label":   "patients",
        "content": "name,age,symptoms\nAlice,30,fever cough\nBob,25,headache fatigue\nCarol,45,chest pain shortness of breath"
      },
      "subscribe": "pipeline/start~first;pipeline/next~next",
      "publish":   "row~pipeline/row;exhausted~player/done"
    },
    {
      "type": "slm:llm-agent",
      "id":   "llm",
      "properties": {
        "model":           "llama3.2",
        "prompt_template": "Given this patient data: {input}\nWhat might be the diagnosis? Answer in one sentence."
      },
      "subscribe": "pipeline/row~input",
      "publish":   "output~pipeline/llm-out;output~pipeline/next"
    },
    {
      "type": "slm:console-display",
      "id":   "display",
      "properties": {"label": "Diagnosis"},
      "subscribe": "pipeline/llm-out~show"
    }
  ]
}
