{
  "title": "Text source → console display",
  "imports": [
    "noid:data.text_source",
    "noid:basic.console_display"
  ],
  "components": [
    {
      "type": "data:text-source",
      "id":   "src",
      "properties": {
        "label": "dinosaur",
        "content":  "The dinosaur jumped into the mud."
      },
      "subscribe": "player/start~load",
      "publish": "text~pipeline/text"
    },
    {
      "type": "basic:console-display",
      "id":   "display",
      "properties": {"label": "Text", "field": "content"},
      "subscribe": "pipeline/text~show",
      "publish": "output~player/done"
    }
  ]
}
