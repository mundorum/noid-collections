{
  "title": "SLM Agents demo — text → LLM → console",
  "imports": [
    "../noid_collections/slm_agents/text_source/text_source.py",
    "../noid_collections/slm_agents/llm/llm.py",
    "../noid_collections/slm_agents/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "slm:text-source",
      "id":   "src",
      "properties": {
        "label":        "question",
        "text":         "What is the capital of France?",
        "auto_publish": true
      },
      "publish": "text~pipeline/input"
    },
    {
      "type": "slm:llm-agent",
      "id":   "llm",
      "properties": {
        "model":           "llama3.2",
        "prompt_template": "Answer briefly: {input}"
      },
      "subscribe": "pipeline/input~input",
      "publish":   "output~pipeline/llm-out;output~player/done"
    },
    {
      "type": "slm:console-display",
      "id":   "display",
      "properties": {"label": "LLM Reply"},
      "subscribe": "pipeline/llm-out~show"
    }
  ]
}
