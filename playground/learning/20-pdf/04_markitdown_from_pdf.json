{
  "title": "PDF extraction — MarkItDown → postprocess → file (run from project root)",
  "imports": [
    "../../../noid_collections/pdf/extractor_markitdown/extractor_markitdown.py",
    "../../../noid_collections/pdf/postprocessor/postprocessor.py",
    "../../../noid_collections/data/text_writer/text_writer.py",
    "../../../noid_collections/basic/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "pdf:extractor-markitdown",
      "id":   "extractor",
      "properties": {
        "input_file": "playground/learning/20-pdf/pdf/ulisses_james_joyce.pdf"
      },
      "subscribe": "player/start~extract",
      "publish": "text~pipeline/text;done~pipeline/done;error~pipeline/error;status~pipeline/status"
    },
    {
      "type": "pdf:postprocessor",
      "id":   "postproc",
      "properties": {
        "source": "markitdown",
        "format": "markdown"
      },
      "subscribe": "pipeline/text~text;pipeline/done~done",
      "publish":   "text~pipeline/clean;done~pipeline/clean-done;status~pipeline/status"
    },
    {
      "type": "data:text-writer",
      "id":   "writer",
      "properties": {
        "output_file": "playground/learning/20-pdf/text/ulisses_james_joyce_markitdown.md"
      },
      "subscribe": "pipeline/clean~text;pipeline/clean-done~done",
      "publish":   "written~player/done"
    },
    {
      "type": "basic:console-display",
      "id":   "progress",
      "properties": {"label": "Progress", "pretty": false},
      "subscribe": "pipeline/status~show;pipeline/error~show"
    }
  ]
}
