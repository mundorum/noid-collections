{
  "title": "PDF text extraction — PyMuPDF → file (run from project root)",
  "imports": [
    "../../../noid_collections/pdf/extractor_pymupdf/extractor_pymupdf.py",
    "../../../noid_collections/data/file_writer/file_writer.py"
  ],
  "components": [
    {
      "type": "pdf:extractor-pymupdf",
      "id":   "extractor",
      "properties": {
        "input_file":   "playground/learning/20-pdf/case_teaching_in_medicine_1906.pdf",
        "output_mode":  "complete",
        "auto_extract": true
      },
      "publish": "text~pipeline/text;done~pipeline/done;error~pipeline/error"
    },
    {
      "type": "data:file-writer",
      "id":   "writer",
      "properties": {
        "output_file": "playground/learning/20-pdf/output_01_text.txt"
      },
      "subscribe": "pipeline/text~text;pipeline/done~done",
      "publish":   "written~player/done"
    }
  ]
}
