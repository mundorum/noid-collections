{
  "title": "PDF page-by-page — PyMuPDF → postprocess (page_by_page) → file (run from project root)",
  "imports": [
    "../../../noid_collections/pdf/extractor_pymupdf/extractor_pymupdf.py",
    "../../../noid_collections/pdf/postprocessor/postprocessor.py",
    "../../../noid_collections/data/text_writer/text_writer.py",
    "../../../noid_collections/basic/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "pdf:extractor-pymupdf",
      "id":   "extractor",
      "properties": {
        "input_file":  "playground/learning/20-pdf/pdf/ulisses_james_joyce.pdf",
        "output_mode": "page_by_page"
      },
      "subscribe": "player/start~extract",
      "publish": "page~pipeline/page;done~pipeline/done;status~pipeline/status"
    },
    {
      "type": "pdf:postprocessor",
      "id":   "postproc",
      "properties": {
        "source":      "pymupdf",
        "format":      "markdown",
        "output_mode": "page_by_page"
      },
      "subscribe": "pipeline/page~page;pipeline/done~done",
      "publish":   "page~pipeline/clean-page;done~pipeline/clean-done;status~pipeline/status"
    },
    {
      "type": "data:text-writer",
      "id":   "writer",
      "properties": {
        "output_file":    "playground/learning/20-pdf/text/ulisses_james_joyce_pymupdf_paged.md",
        "page_separator": "\n\n"
      },
      "subscribe": "pipeline/clean-page~page;pipeline/clean-done~done",
      "publish":   "written~player/done"
    },
    {
      "type": "basic:console-display",
      "id":   "progress",
      "properties": {"label": "Progress", "pretty": false},
      "subscribe": "pipeline/status~show;pipeline/error~show"
    }
  ]
}
