{
  "title": "PDF text extraction — PyMuPDF → file (run from project root)",
  "imports": [
    "../../../noid_collections/pdf/extractor_pymupdf/extractor_pymupdf.py",
    "../../../noid_collections/data/text_writer/text_writer.py",
    "../../../noid_collections/basic/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "pdf:extractor-pymupdf",
      "id":   "extractor",
      "properties": {
        "input_file":  "playground/learning/20-pdf/pdf/ulisses_james_joyce.pdf",
        "output_mode": "complete"
      },
      "subscribe": "player/start~extract",
      "publish": "text~pipeline/text;done~pipeline/done;error~pipeline/error;status~pipeline/status"
    },
    {
      "type": "data:text-writer",
      "id":   "writer",
      "properties": {
        "output_file": "playground/learning/20-pdf/text/ulisses-james-joyce.txt"
      },
      "subscribe": "pipeline/text~text;pipeline/done~done",
      "publish":   "written~player/done"
    },
    {
      "type": "basic:console-display",
      "id":   "progress",
      "properties": {"label": "Progress", "pretty": false},
      "subscribe": "pipeline/status~show;pipeline/error~show"
    }
  ]
}
