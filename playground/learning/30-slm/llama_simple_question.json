{
  "title": "LM Agents demo — text → LM → console",
  "imports": [
    "noid:data.text_source",
    "noid:lm_agents.lm",
    "noid:basic.console_display"
  ],
  "components": [
    {
      "type": "data:text-source",
      "id":   "src",
      "properties": {
        "label": "question",
        "content":  "What is the capital of France?"
      },
      "subscribe": "player/start~load",
      "publish": "text~pipeline/input"
    },
    {
      "type": "lm:lm-agent",
      "id":   "lm",
      "properties": {
        "model":           "llama3.2:3b",
        "prompt_template": "Answer briefly: {input}"
      },
      "subscribe": "pipeline/input~input",
      "publish":   "output~pipeline/lm-out"
    },
    {
      "type": "basic:console-display",
      "id":   "display",
      "properties": {"label": "LM Reply"},
      "subscribe": "pipeline/lm-out~show",
      "publish":   "output~player/done"
    }
  ]
}
