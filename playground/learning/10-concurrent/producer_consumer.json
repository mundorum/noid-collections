{
  "title": "Producer-Consumer (bus queuing demo)",
  "imports": [
    "producer.py",
    "consumer.py",
    "noid:basic.console_display"
  ],
  "components": [
    {
      "type":       "learning:producer",
      "id":         "prod",
      "properties": {"count": 10},
      "publish":    "item~pipeline/items;done~player/done"
    },
    {
      "type":       "learning:consumer",
      "id":         "cons",
      "properties": {"label": "consumer"},
      "subscribe":  "pipeline/items~item",
      "publish":    "consumed~pipeline/consumed"
    },
    {
      "type":       "basic:console-display",
      "id":         "display",
      "properties": {"label": ""},
      "subscribe":  "pipeline/items~show;pipeline/consumed~show"
    }
  ]
}
