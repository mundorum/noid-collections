{
  "title": "Copy text source",
  "imports": [
    "noid:data.text_source",
    "noid:data.text_writer"
  ],
  "components": [
    {
      "type": "data:text-source",
      "id":   "src",
      "properties": {
        "label": "dinosaur",
        "input_file":  "scene:dinosaur.txt"
      },
      "subscribe": "player/start~load",
      "publish": "text~pipeline/text;done~pipeline/done"
    },
    {
      "type": "data:text-writer",
      "id":   "writer",
      "properties": {
        "output_file": "scene:dinosaur-copy.txt"
      },
      "subscribe": "pipeline/text~text;pipeline/done~done",
      "publish":   "written~player/done"
    }
  ]
}
