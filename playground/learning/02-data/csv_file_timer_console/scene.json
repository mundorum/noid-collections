{
  "title": "Text source → console display",
  "imports": [
    "noid:basic.timer",
    "noid:data.csv_source",
    "noid:basic.console_display"
  ],
  "components": [
    {
      "type": "basic:timer",
      "id": "timer",
      "properties": {"period": 1.0},
      "subscribe": "player/start~start",
      "publish":   "pulse~pipeline/tick"
    },
    {
      "type": "data:csv-source",
      "id":   "src",
      "properties": {
        "input_file": "scene:zombie-health-age-days-recovery.csv",
        "sample_size": 3
      },
      "subscribe": "player/start~first;pipeline/tick~next",
      "publish": "schema~pipeline/schema;row~pipeline/row;exhausted~player/done"
    },
    {
      "type": "basic:console-display",
      "id":   "display",
      "properties": {"label": "Text"},
      "subscribe": "pipeline/schema~show;pipeline/row~show"
    }
  ]
}
