{
  "title": "Prolog reasoning → console display",
  "imports": [
    "../../../noid_collections/data/text_source/text_source.py",
    "../../../noid_collections/logic/prolog/prolog.py",
    "../../../noid_collections/basic/console_display/console_display.py"
  ],
  "components": [
    {
      "type": "data:text-source",
      "id":   "trigger",
      "properties": {
        "label":        "query",
        "text":         "mortal(X)",
        "auto_publish": true
      },
      "publish": "text~pipeline/query-in"
    },
    {
      "type": "logic:prolog",
      "id":   "reasoner",
      "properties": {
        "facts_rules": "human(socrates).\nhuman(plato).\nmortal(X) :- human(X)."
      },
      "subscribe": "pipeline/query-in~query",
      "publish":   "result~pipeline/result;error~pipeline/result;done~player/done"
    },
    {
      "type": "basic:console-display",
      "id":   "display",
      "properties": {"label": "Prolog"},
      "subscribe": "pipeline/result~show"
    }
  ]
}
